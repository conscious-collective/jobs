---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Terms of Use | Sustainability Jobs"
  description="Terms governing use of Sustainability Jobs, the free sustainability job board by C22 Open Source Foundation."
>
  <Nav />

  <main class="pt-28 pb-24">
    <div class="max-w-[720px] mx-auto px-6 lg:px-10">

      <div class="section-rule mb-4"></div>
      <span class="tag">Legal</span>
      <h1 class="font-display font-bold text-[#f0f0f0] text-3xl tracking-tight mt-4 mb-2">Terms of Use</h1>
      <p class="text-[13px] text-[#444] mb-10">Last updated: April 2, 2026</p>

      <!-- Acceptance -->
      <div class="border-t border-[#1a1a22] pt-10 mb-12">
        <h2 class="font-display font-bold text-[#f0f0f0] text-lg tracking-tight mb-4">Acceptance</h2>
        <p class="text-[14px] text-[#888] leading-relaxed">
          By accessing or using Sustainability Jobs ("the Platform"), you agree to these Terms of Use. Sustainability Jobs is operated by <strong class="text-[#aaa]">C22 Open Source Foundation</strong>. If you do not agree, please do not use the Platform.
        </p>
      </div>

      <!-- The service -->
      <div class="border-t border-[#1a1a22] pt-10 mb-12">
        <h2 class="font-display font-bold text-[#f0f0f0] text-lg tracking-tight mb-4">The service</h2>
        <p class="text-[14px] text-[#888] leading-relaxed mb-4">
          Sustainability Jobs is a free job board focused on the sustainability ecosystem. It allows employers to post roles and job seekers to apply to them. The Platform is provided free of charge with no guarantee of uptime, availability, or suitability for any particular purpose.
        </p>
        <p class="text-[14px] text-[#888] leading-relaxed">
          We reserve the right to modify, suspend, or discontinue any part of the Platform at any time without notice.
        </p>
      </div>

      <!-- Accounts -->
      <div class="border-t border-[#1a1a22] pt-10 mb-12">
        <h2 class="font-display font-bold text-[#f0f0f0] text-lg tracking-tight mb-4">Accounts</h2>
        <ul class="space-y-3 text-[14px] text-[#888] leading-relaxed list-none">
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> You must provide an accurate email address at registration.</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> You are responsible for keeping your password secure. Do not share your credentials.</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> One account per person or organisation. Creating accounts to circumvent a suspension is prohibited.</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> You must be at least 16 years old to create an account.</li>
        </ul>
      </div>

      <!-- Employer rules -->
      <div class="border-t border-[#1a1a22] pt-10 mb-12">
        <h2 class="font-display font-bold text-[#f0f0f0] text-lg tracking-tight mb-4">Employer responsibilities</h2>
        <p class="text-[14px] text-[#888] leading-relaxed mb-4">
          By posting a job listing you confirm that:
        </p>
        <ul class="space-y-3 text-[14px] text-[#888] leading-relaxed list-none">
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> The role is real, current, and legitimately available.</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> Your organisation operates within the sustainability ecosystem — clean energy, climate tech, environmental science, ESG, green finance, circular economy, or related fields.</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> The listing does not misrepresent the role, compensation, location, or company.</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> You will handle applications in good faith and in accordance with applicable employment law.</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> You will not use applicant data for any purpose other than evaluating them for the role applied to.</li>
        </ul>
      </div>

      <!-- Seeker rules -->
      <div class="border-t border-[#1a1a22] pt-10 mb-12">
        <h2 class="font-display font-bold text-[#f0f0f0] text-lg tracking-tight mb-4">Seeker responsibilities</h2>
        <ul class="space-y-3 text-[14px] text-[#888] leading-relaxed list-none">
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> Applications must be genuine. Automated or bulk applications are prohibited.</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> Cover letters and profile information must be truthful.</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> Do not submit applications on behalf of another person without their explicit consent.</li>
        </ul>
      </div>

      <!-- Prohibited content -->
      <div class="border-t border-[#1a1a22] pt-10 mb-12">
        <h2 class="font-display font-bold text-[#f0f0f0] text-lg tracking-tight mb-4">Prohibited content &amp; conduct</h2>
        <p class="text-[14px] text-[#888] leading-relaxed mb-4">The following are not permitted on the Platform:</p>
        <ul class="space-y-3 text-[14px] text-[#888] leading-relaxed list-none">
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> Spam, phishing, or any form of deceptive content</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> Job listings that are unrelated to sustainability or that exist solely to harvest personal data</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> Discriminatory listings that violate applicable equal-opportunity laws</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> Scraping, crawling, or automated data extraction without prior written permission</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> Attempting to circumvent authentication, exploit vulnerabilities, or interfere with the Platform's operation</li>
          <li class="flex gap-3"><span class="text-accent flex-shrink-0">—</span> Impersonating another person or organisation</li>
        </ul>
      </div>

      <!-- Intellectual property -->
      <div class="border-t border-[#1a1a22] pt-10 mb-12">
        <h2 class="font-display font-bold text-[#f0f0f0] text-lg tracking-tight mb-4">Intellectual property</h2>
        <p class="text-[14px] text-[#888] leading-relaxed mb-4">
          The Sustainability Jobs source code is open source and available on GitHub under its stated licence. The C22 brand, logo, and design system remain the property of C22 Open Source Foundation.
        </p>
        <p class="text-[14px] text-[#888] leading-relaxed">
          Content you submit (job listings, cover letters, profile data) remains yours. By submitting it, you grant C22 Open Source Foundation a limited licence to display and transmit that content as needed to operate the Platform.
        </p>
      </div>

      <!-- Disclaimers -->
      <div class="border-t border-[#1a1a22] pt-10 mb-12">
        <h2 class="font-display font-bold text-[#f0f0f0] text-lg tracking-tight mb-4">Disclaimers</h2>
        <p class="text-[14px] text-[#888] leading-relaxed mb-4">
          C22 Open Source Foundation does not endorse any employer or job listing, verify the accuracy of listing content, or guarantee employment outcomes. We are a venue, not a recruiter or employment agency.
        </p>
        <p class="text-[14px] text-[#888] leading-relaxed">
          The Platform is provided "as is" without warranties of any kind, express or implied. C22 Open Source Foundation will not be liable for any indirect, incidental, or consequential damages arising from your use of the Platform.
        </p>
      </div>

      <!-- Enforcement -->
      <div class="border-t border-[#1a1a22] pt-10 mb-12">
        <h2 class="font-display font-bold text-[#f0f0f0] text-lg tracking-tight mb-4">Enforcement &amp; termination</h2>
        <p class="text-[14px] text-[#888] leading-relaxed">
          We may remove any content or suspend any account that violates these Terms, at our sole discretion, with or without notice. If your account is suspended, you may contact <a href="mailto:policy@c22.space" class="text-accent hover:text-white transition-colors">policy@c22.space</a> to dispute the decision.
        </p>
      </div>

      <!-- Changes -->
      <div class="border-t border-[#1a1a22] pt-10 mb-12">
        <h2 class="font-display font-bold text-[#f0f0f0] text-lg tracking-tight mb-4">Changes to these Terms</h2>
        <p class="text-[14px] text-[#888] leading-relaxed">
          We may update these Terms from time to time. The "Last updated" date at the top of this page will reflect any changes. Continued use of the Platform after changes are posted constitutes your acceptance of the revised Terms.
        </p>
      </div>

      <!-- Contact -->
      <div class="border border-[#1a1a22] p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, #00e5ff, #a855f7); box-shadow: 0 0 8px rgba(0,229,255,0.4);"></div>
        <div class="text-[10px] font-display tracking-[0.2em] uppercase text-accent mb-3">Questions?</div>
        <p class="text-[14px] text-[#888] leading-relaxed mb-4">
          Contact C22 Open Source Foundation at <a href="mailto:policy@c22.space" class="text-accent hover:text-white transition-colors">policy@c22.space</a>.
        </p>
        <a href="/privacy" class="text-[12px] font-display tracking-widest uppercase text-[#555] hover:text-[#888] transition-colors">Read our Privacy Policy →</a>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>
