---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Reset Password | Sustainability Jobs"
  description="Set a new password for your C22 Jobs account."
>
  <Nav />

  <main class="min-h-screen flex flex-col justify-center py-32">
    <div class="max-w-[480px] mx-auto w-full px-6">

      <div class="mb-8 text-center">
        <div class="section-rule mb-4 mx-auto" style="width:40px;"></div>
        <span class="tag">C22 Jobs</span>
        <h1 class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight mt-4">Set new password</h1>
        <p class="text-[13px] text-[#555] mt-2">Choose a new password for your account.</p>
      </div>

      <div id="invalid-token" class="hidden text-center space-y-4">
        <p class="text-[13px] text-[#ff6b35]">This reset link is invalid or has expired.</p>
        <a href="/forgot-password"
          class="inline-block py-3 px-6 text-[12px] font-display tracking-widest uppercase border border-[#1a1a22] text-[#888] hover:text-accent hover:border-accent transition-colors">
          Request New Link
        </a>
      </div>

      <form id="reset-form" class="space-y-6">
        <div>
          <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">New Password</label>
          <input type="password" id="rp-password" required placeholder="min 8 characters"
            class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
        </div>
        <div>
          <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Confirm Password</label>
          <input type="password" id="rp-confirm" required placeholder="repeat password"
            class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
        </div>

        <div id="rp-error" class="hidden text-[13px] text-[#ff6b35]"></div>

        <button type="submit" id="rp-btn"
          class="w-full py-4 text-[13px] font-display font-medium tracking-widest uppercase bg-accent text-[#080808] hover:bg-white transition-colors duration-200 disabled:opacity-40 disabled:cursor-not-allowed"
          style="clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);">
          Update Password →
        </button>
      </form>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const token = params.get('token');

  if (!token) {
    document.getElementById('reset-form')!.classList.add('hidden');
    document.getElementById('invalid-token')!.classList.remove('hidden');
  }

  const form = document.getElementById('reset-form')!;
  const btn = document.getElementById('rp-btn') as HTMLButtonElement;
  const errEl = document.getElementById('rp-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const password = (document.getElementById('rp-password') as HTMLInputElement).value;
    const confirm = (document.getElementById('rp-confirm') as HTMLInputElement).value;

    if (password !== confirm) {
      errEl.textContent = 'Passwords do not match.';
      errEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Updating…';
    errEl.classList.add('hidden');

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password }),
      });

      const data = await res.json() as { ok?: boolean; error?: string };

      if (res.ok) {
        window.location.href = '/auth?mode=signin';
      } else {
        errEl.textContent = data.error ?? 'Something went wrong.';
        errEl.classList.remove('hidden');
        if (data.error?.includes('expired') || data.error?.includes('Invalid')) {
          document.getElementById('reset-form')!.classList.add('hidden');
          document.getElementById('invalid-token')!.classList.remove('hidden');
        } else {
          btn.disabled = false;
          btn.textContent = 'Update Password →';
        }
      }
    } catch {
      errEl.textContent = 'Network error. Please try again.';
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Update Password →';
    }
  });
</script>
