---
const year = new Date().getFullYear();
---

<footer class="border-t border-[#1a1a22] relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(0,229,255,0.1), transparent);"></div>

  <div class="max-w-[1200px] mx-auto px-6 lg:px-10 py-10">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">

      <div class="flex flex-col gap-1">
        <a href="https://c22.space" class="font-display font-bold text-[15px] text-[#f0f0f0] tracking-tight hover:text-accent transition-colors">C22</a>
        <span class="text-[11px] text-[#2a2a2a] tracking-[0.15em] uppercase font-display">Sustainability Jobs</span>
      </div>

      <nav class="flex items-center gap-6 flex-wrap">
        <a href="/" class="text-[11px] text-[#383838] hover:text-[#f0f0f0] transition-colors tracking-[0.12em] uppercase font-display">Browse Jobs</a>
        <a href="/auth?mode=signup&role=employer" class="text-[11px] text-[#383838] hover:text-[#f0f0f0] transition-colors tracking-[0.12em] uppercase font-display">Post a Job</a>
        <a href="/auth?mode=signup&role=seeker" class="text-[11px] text-[#383838] hover:text-[#f0f0f0] transition-colors tracking-[0.12em] uppercase font-display">Sign Up</a>
        <a href="https://c22.space" class="text-[11px] text-accent hover:text-white transition-colors tracking-[0.12em] uppercase font-display" style="text-shadow: 0 0 8px rgba(0,229,255,0.3);">c22.space →</a>
      </nav>

      <div class="flex items-center gap-5">
        <a href="mailto:hello@agent22.io" class="text-[11px] text-[#383838] hover:text-[#f0f0f0] transition-colors tracking-wide">hello@c22.space</a>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-[#111] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <p class="text-[10px] text-[#222] tracking-[0.15em] uppercase font-display">
        © {year} C22. All rights reserved.
      </p>
    </div>
  </div>
</footer>
