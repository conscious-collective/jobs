---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Candidate Profile | Sustainability Jobs"
  description="Sustainability professional profile."
>
  <Nav />

  <main class="pt-28 pb-24">
    <div class="max-w-[700px] mx-auto px-6">

      <div id="loading" class="py-20 text-center text-[#444] font-display text-[13px] tracking-widest uppercase">
        Loading…
      </div>

      <div id="notfound" class="hidden py-20 text-center">
        <p class="text-[#555] text-[14px]">Profile not found.</p>
        <a href="/" class="text-accent hover:text-white transition-colors text-[13px] mt-2 inline-block">← Browse jobs</a>
      </div>

      <div id="content" class="hidden">

        <!-- Header -->
        <div class="flex items-start gap-6 mb-10">
          <div id="avatar-wrap" class="shrink-0">
            <div class="w-16 h-16 rounded-full border border-[#1a1a22] bg-[#0d0d10] overflow-hidden flex items-center justify-center">
              <img id="avatar" src="" alt="" class="hidden w-full h-full object-cover" />
              <svg id="avatar-placeholder" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2a2a2a" stroke-width="1"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            </div>
          </div>
          <div class="flex-1 min-w-0 pt-1">
            <div class="section-rule mb-4"></div>
            <div class="flex flex-wrap items-center gap-3">
              <h1 id="full-name" class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight"></h1>
              <span id="otw-badge" class="hidden text-[10px] font-display tracking-widest uppercase px-2.5 py-1 border border-emerald-800/40 text-emerald-500">Open to Work</span>
            </div>
            <div id="meta" class="flex flex-wrap gap-3 mt-2"></div>
          </div>
        </div>

        <!-- Bio -->
        <div id="bio-wrap" class="hidden mb-10">
          <p class="text-[11px] font-display tracking-widest uppercase text-[#444] mb-3">About</p>
          <p id="bio" class="text-[14px] text-[#888] leading-relaxed"></p>
        </div>

        <!-- Skills -->
        <div id="skills-wrap" class="hidden mb-10">
          <p class="text-[11px] font-display tracking-widest uppercase text-[#444] mb-4">Skills</p>
          <div id="skills-list" class="flex flex-wrap gap-2"></div>
        </div>

        <!-- Links -->
        <div id="links-wrap" class="hidden">
          <p class="text-[11px] font-display tracking-widest uppercase text-[#444] mb-4">Links</p>
          <div id="links-list" class="flex flex-wrap gap-3"></div>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  async function init() {
    const id = new URLSearchParams(window.location.search).get('id');
    if (!id) {
      document.getElementById('loading')!.classList.add('hidden');
      document.getElementById('notfound')!.classList.remove('hidden');
      return;
    }

    const res = await fetch(`/api/candidate/${id}`);
    document.getElementById('loading')!.classList.add('hidden');

    if (!res.ok) {
      document.getElementById('notfound')!.classList.remove('hidden');
      return;
    }

    const p = await res.json() as any;
    document.getElementById('content')!.classList.remove('hidden');

    document.title = `${p.full_name ?? 'Candidate'} | Sustainability Jobs`;

    if (p.avatar) {
      const img = document.getElementById('avatar') as HTMLImageElement;
      img.src = p.avatar;
      img.alt = p.full_name ?? '';
      img.classList.remove('hidden');
      document.getElementById('avatar-placeholder')!.classList.add('hidden');
    }

    document.getElementById('full-name')!.textContent = p.full_name ?? 'Anonymous';
    if (p.open_to_work) document.getElementById('otw-badge')!.classList.remove('hidden');

    const meta = document.getElementById('meta')!;
    const metaParts: string[] = [];
    if (p.location) metaParts.push(`<span class="text-[13px] text-[#555] font-display">${p.location}</span>`);
    if (p.years_experience) {
      const expMap: Record<string, string> = {
        '0-1': '< 1 yr exp', '1-3': '1–3 yrs exp', '3-5': '3–5 yrs exp',
        '5-10': '5–10 yrs exp', '10+': '10+ yrs exp',
      };
      metaParts.push(`<span class="text-[13px] text-[#555] font-display">${expMap[p.years_experience] ?? p.years_experience}</span>`);
    }
    meta.innerHTML = metaParts.join('<span class="text-[#2a2a2a]">·</span>');

    if (p.bio) {
      document.getElementById('bio')!.textContent = p.bio;
      document.getElementById('bio-wrap')!.classList.remove('hidden');
    }

    const skills: string[] = p.skills ?? [];
    if (skills.length) {
      document.getElementById('skills-list')!.innerHTML = skills.map(s =>
        `<span class="text-[11px] px-2.5 py-1 border border-accent/20 text-accent/60 font-display tracking-wide">${s}</span>`
      ).join('');
      document.getElementById('skills-wrap')!.classList.remove('hidden');
    }

    const links: string[] = [];
    if (p.linkedin_url) links.push(`<a href="${p.linkedin_url}" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-[11px] font-display tracking-widest uppercase border border-[#1a1a22] text-[#666] hover:border-accent/50 hover:text-accent transition-all">LinkedIn →</a>`);
    if (p.portfolio_url) links.push(`<a href="${p.portfolio_url}" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 text-[11px] font-display tracking-widest uppercase border border-[#1a1a22] text-[#666] hover:border-accent/50 hover:text-accent transition-all">Portfolio →</a>`);
    if (links.length) {
      document.getElementById('links-list')!.innerHTML = links.join('');
      document.getElementById('links-wrap')!.classList.remove('hidden');
    }
  }

  init();
</script>
