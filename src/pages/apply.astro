---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Apply | Sustainability Jobs"
  description="Apply to sustainability jobs. Quick application, no fluff."
>
  <Nav />

  <main class="pt-28 pb-24">
    <div class="max-w-[640px] mx-auto px-6">

      <div id="checking" class="py-20 text-center text-[#444] font-display text-[13px] tracking-widest uppercase">
        Loading…
      </div>

      <div id="apply-content" class="hidden">
        <a href="#" id="back-link" class="inline-flex items-center gap-2 text-[12px] text-[#444] hover:text-accent transition-colors font-display tracking-wider uppercase mb-10">
          <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M13 7H1M1 7L7 1M1 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Back to Job
        </a>

        <div class="section-rule mb-4"></div>
        <span class="tag">Apply</span>
        <h1 class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight mt-4 mb-1">
          Apply for <span id="job-title-display" class="text-accent"></span>
        </h1>
        <p id="job-meta" class="text-[13px] text-[#555] mb-10"></p>

        <form id="apply-form" class="space-y-7">

          <!-- Required contact fields -->
          <div class="pb-6 border-b border-[#1a1a22]">
            <p class="text-[10px] font-display tracking-widest uppercase text-[#333] mb-5">Contact Details</p>

            <div class="space-y-7">
              <div>
                <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">
                  Full Name <span class="text-[#ff6b35]">*</span>
                </label>
                <input type="text" id="full-name" required placeholder="Jane Smith"
                  class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
              </div>

              <div>
                <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">
                  Email <span class="text-[#ff6b35]">*</span>
                </label>
                <input type="email" id="email" readonly
                  class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#888] focus:outline-none cursor-default" />
              </div>

              <div>
                <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">
                  Phone Number <span class="text-[#ff6b35]">*</span>
                </label>
                <input type="tel" id="phone" required placeholder="+44 7700 000000"
                  class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
              </div>

              <div>
                <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">
                  Resume <span class="text-[#ff6b35]">*</span>
                </label>
                <!-- Hidden field holds the URL; submit logic reads this unchanged -->
                <input type="text" id="resume-url" class="hidden" />
                <input type="file" id="resume-input" accept=".pdf,.doc,.docx" class="hidden" />
                <div class="flex items-center gap-3 border-b border-[#1a1a22] pb-2.5">
                  <button type="button" id="resume-btn"
                    class="shrink-0 text-[11px] font-display tracking-widest uppercase px-3 py-1.5 border border-[#1a1a22] text-[#666] hover:border-accent hover:text-accent transition-colors">
                    Upload
                  </button>
                  <span id="resume-name" class="text-[13px] text-[#444] truncate">No resume selected</span>
                  <button type="button" id="remove-resume-btn" class="hidden ml-auto shrink-0 text-[11px] font-display uppercase text-[#444] hover:text-[#ff6b35] transition-colors">Remove</button>
                </div>
                <p id="resume-status" class="text-[12px] mt-1.5"></p>
                <p class="text-[11px] text-[#333] mt-1">PDF, DOC or DOCX · Max 5 MB</p>
              </div>
            </div>
          </div>

          <!-- Application fields -->
          <div class="space-y-7">
            <div>
              <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Cover Letter <span class="text-[#333]">(optional)</span></label>
              <textarea id="cover-letter" rows="6" placeholder="Tell them why you're the right fit for this role..."
                class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors resize-none"></textarea>
            </div>

            <div>
              <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">What interests you about joining this company? <span class="text-[#333]">(optional)</span></label>
              <textarea id="interest-statement" rows="4" placeholder="What excites you about this company's mission and culture..."
                class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors resize-none"></textarea>
            </div>

            <div>
              <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">LinkedIn Profile <span class="text-[#333]">(optional)</span></label>
              <input type="url" id="linkedin" placeholder="https://linkedin.com/in/you"
                class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
            </div>

            <div>
              <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Portfolio / Website <span class="text-[#333]">(optional)</span></label>
              <input type="url" id="portfolio" placeholder="https://yoursite.com"
                class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
            </div>
          </div>

          <!-- Dynamic qualifying questions rendered by JS -->
          <div id="questions-section" class="hidden space-y-7">
            <div class="section-rule"></div>
            <p class="text-[10px] font-display tracking-widest uppercase text-[#333]">Employer Questions</p>
            <div id="questions-list" class="space-y-7"></div>
          </div>

          <div id="apply-error" class="hidden text-[13px] text-[#ff6b35]"></div>
          <div id="apply-success" class="hidden space-y-4">
            <div class="text-[13px] text-accent p-4 border border-accent/20 bg-accent/5">
              Application submitted! Track its status in your <a href="/seeker/dashboard" class="underline">dashboard</a>.
            </div>
            <div id="profile-nudge" class="hidden border border-[#1a1a22] bg-[#080808] p-5">
              <div class="flex items-center justify-between gap-4 mb-3">
                <div>
                  <p class="text-[12px] font-display tracking-widest uppercase text-[#555] mb-1">Your Profile Strength</p>
                  <div class="flex items-center gap-2">
                    <span id="nudge-pct" class="text-[20px] font-display font-bold" style="color:#fbbf24">0%</span>
                    <span id="nudge-tier" class="text-[10px] font-display tracking-widest uppercase px-2 py-0.5 border border-amber-800/30 text-amber-500">Rising</span>
                  </div>
                </div>
                <a href="/seeker/profile"
                  class="shrink-0 inline-flex items-center gap-2 px-4 py-2.5 text-[11px] font-display tracking-widest uppercase border border-[#1a1a22] text-[#555] hover:border-accent/50 hover:text-accent transition-all">
                  Complete Profile →
                </a>
              </div>
              <div class="h-1 bg-[#111] w-full overflow-hidden mb-2">
                <div id="nudge-fill" class="h-full w-0 transition-all duration-700 ease-out" style="background: linear-gradient(90deg,#fbbf24,#f97316);"></div>
              </div>
              <p id="nudge-tip" class="text-[12px] text-[#444]"></p>
            </div>
          </div>

          <button type="submit" id="apply-btn"
            class="inline-flex items-center gap-2 px-7 py-4 text-[13px] font-display font-medium tracking-widest uppercase bg-accent text-[#080808] hover:bg-white transition-colors duration-200 disabled:opacity-40"
            style="clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 0 100%);">
            Submit Application
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const jobId = params.get('id');

  interface Question { id: string; question: string; required: boolean; }

  async function init() {
    if (!jobId) { window.location.href = '/'; return; }

    const meRes = await fetch('/api/auth/me', { credentials: 'include' });
    if (!meRes.ok) {
      window.location.href = `/auth?mode=signup&role=seeker&redirect=${encodeURIComponent(window.location.pathname + window.location.search)}`;
      return;
    }
    const me = await meRes.json() as { role: string; email: string };
    if (me.role !== 'seeker') { window.location.href = '/'; return; }

    // Fetch job and profile in parallel
    const [jobRes, profileRes] = await Promise.all([
      fetch(`/api/jobs/${jobId}`, { credentials: 'include' }),
      fetch('/api/profile', { credentials: 'include' }),
    ]);

    if (!jobRes.ok) { window.location.href = '/'; return; }
    const job = await jobRes.json() as any;
    const profile = profileRes.ok ? await profileRes.json() as any : {};

    document.getElementById('checking')!.classList.add('hidden');
    document.getElementById('apply-content')!.classList.remove('hidden');
    document.getElementById('job-title-display')!.textContent = job.title;
    document.getElementById('job-meta')!.textContent = `${job.company}${job.location ? ' · ' + job.location : ''}`;
    (document.getElementById('back-link') as HTMLAnchorElement).href = `/view?id=${jobId}`;

    // Pre-fill from profile
    (document.getElementById('email') as HTMLInputElement).value = me.email;
    if (profile.full_name) (document.getElementById('full-name') as HTMLInputElement).value = profile.full_name;
    if (profile.phone) (document.getElementById('phone') as HTMLInputElement).value = profile.phone;
    if (profile.linkedin_url) (document.getElementById('linkedin') as HTMLInputElement).value = profile.linkedin_url;
    if (profile.portfolio_url) (document.getElementById('portfolio') as HTMLInputElement).value = profile.portfolio_url;
    if (profile.resume_url) {
      (document.getElementById('resume-url') as HTMLInputElement).value = profile.resume_url;
      const filename = profile.resume_url.split('/').pop() ?? 'resume';
      document.getElementById('resume-name')!.textContent = filename;
      (document.getElementById('resume-name')! as HTMLElement).style.color = '#f0f0f0';
      document.getElementById('remove-resume-btn')!.classList.remove('hidden');
    }

    // Resume upload
    const resumeInput = document.getElementById('resume-input') as HTMLInputElement;
    document.getElementById('resume-btn')!.addEventListener('click', () => resumeInput.click());
    resumeInput.addEventListener('change', async () => {
      const file = resumeInput.files?.[0];
      if (!file) return;
      const statusEl = document.getElementById('resume-status')!;
      statusEl.textContent = 'Uploading…';
      statusEl.style.color = '#888';
      const fd = new FormData();
      fd.append('file', file);
      try {
        const res = await fetch('/api/upload', { method: 'POST', credentials: 'include', body: fd });
        const data = await res.json() as any;
        if (res.ok) {
          (document.getElementById('resume-url') as HTMLInputElement).value = data.url;
          document.getElementById('resume-name')!.textContent = file.name;
          (document.getElementById('resume-name')! as HTMLElement).style.color = '#f0f0f0';
          document.getElementById('remove-resume-btn')!.classList.remove('hidden');
          statusEl.textContent = 'Resume ready.';
          statusEl.style.color = '#00e5ff';
        } else {
          statusEl.textContent = data.error ?? 'Upload failed.';
          statusEl.style.color = '#ff6b35';
        }
      } catch {
        statusEl.textContent = 'Upload failed.';
        document.getElementById('resume-status')!.style.color = '#ff6b35';
      }
    });
    document.getElementById('remove-resume-btn')!.addEventListener('click', () => {
      (document.getElementById('resume-url') as HTMLInputElement).value = '';
      document.getElementById('resume-name')!.textContent = 'No resume selected';
      (document.getElementById('resume-name')! as HTMLElement).style.color = '';
      document.getElementById('remove-resume-btn')!.classList.add('hidden');
      document.getElementById('resume-status')!.textContent = '';
      resumeInput.value = '';
    });

    // Render qualifying questions
    const questions: Question[] = job.questions ?? [];
    if (questions.length > 0) {
      document.getElementById('questions-section')!.classList.remove('hidden');
      const listEl = document.getElementById('questions-list')!;
      listEl.innerHTML = questions.map((q: Question) => `
        <div>
          <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">
            ${q.question}
            ${q.required ? '<span style="color:#ff6b35">*</span>' : '<span style="color:#333">(optional)</span>'}
          </label>
          <textarea
            data-question-id="${q.id}"
            data-required="${q.required}"
            rows="3"
            placeholder="Your answer…"
            ${q.required ? 'required' : ''}
            class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors resize-none question-answer"></textarea>
        </div>
      `).join('');
    }

    document.getElementById('apply-form')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('apply-btn') as HTMLButtonElement;
      const errEl = document.getElementById('apply-error')!;
      const successEl = document.getElementById('apply-success')!;
      btn.disabled = true; btn.textContent = 'Submitting…';
      errEl.classList.add('hidden');

      const resumeUrl = (document.getElementById('resume-url') as HTMLInputElement).value;
      if (!resumeUrl) {
        errEl.textContent = 'Please upload your resume before submitting.';
        errEl.classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Submit Application';
        return;
      }

      // Collect question answers
      const answers: Array<{ question_id: string; answer: string }> = [];
      document.querySelectorAll<HTMLTextAreaElement>('.question-answer').forEach(ta => {
        answers.push({ question_id: ta.dataset.questionId!, answer: ta.value });
      });

      const res = await fetch('/api/applications', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          job_id: jobId,
          full_name: (document.getElementById('full-name') as HTMLInputElement).value,
          phone: (document.getElementById('phone') as HTMLInputElement).value,
          resume_url: (document.getElementById('resume-url') as HTMLInputElement).value,
          cover_letter: (document.getElementById('cover-letter') as HTMLTextAreaElement).value || undefined,
          interest_statement: (document.getElementById('interest-statement') as HTMLTextAreaElement).value || undefined,
          linkedin_url: (document.getElementById('linkedin') as HTMLInputElement).value || undefined,
          portfolio_url: (document.getElementById('portfolio') as HTMLInputElement).value || undefined,
          answers: answers.filter(a => a.answer),
        }),
      });

      const data = await res.json() as any;
      if (res.ok) {
        successEl.classList.remove('hidden');
        (document.getElementById('apply-form') as HTMLFormElement).reset();
        btn.textContent = 'Submitted ✓';
        // Show profile nudge if profile is incomplete
        showProfileNudge();
      } else {
        errEl.textContent = data.error ?? 'Something went wrong.';
        errEl.classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Submit Application';
      }
    });
  }

  async function showProfileNudge() {
    const FIELDS = [
      { key: 'avatar', pts: 15 }, { key: 'full_name', pts: 10 }, { key: 'bio', pts: 15 },
      { key: 'location', pts: 10 }, { key: 'years_experience', pts: 10 },
      { key: 'skills', pts: 15 }, { key: 'linkedin_url', pts: 10 },
      { key: 'resume_url', pts: 10 }, { key: 'portfolio_url', pts: 5 },
    ];
    const pr = await fetch('/api/profile', { credentials: 'include' });
    if (!pr.ok) return;
    const p = await pr.json() as any;
    const score = FIELDS.reduce((s, f) => {
      const v = p[f.key];
      return s + (f.key === 'skills' ? (Array.isArray(v) && v.length > 0 ? f.pts : 0) : (v ? f.pts : 0));
    }, 0);
    if (score >= 100) return;

    const tierMap = [
      { min: 75, label: 'Pro',      color: '#34d399', grad: '#34d399,#059669' },
      { min: 50, label: 'Advanced', color: '#60a5fa', grad: '#60a5fa,#3b82f6' },
      { min: 25, label: 'Rising',   color: '#fbbf24', grad: '#fbbf24,#f97316' },
      { min: 0,  label: 'Starter',  color: '#555',    grad: '#555,#333' },
    ];
    const tier = tierMap.find(t => score >= t.min)!;
    const missing = FIELDS.filter(f => { const v = p[f.key]; return f.key === 'skills' ? !(Array.isArray(v) && v.length > 0) : !v; });

    const nudge = document.getElementById('profile-nudge')!;
    const pctEl  = document.getElementById('nudge-pct')!;
    const tierEl = document.getElementById('nudge-tier')!;
    const fillEl = document.getElementById('nudge-fill')!;
    const tipEl  = document.getElementById('nudge-tip')!;

    pctEl.textContent  = `${score}%`;
    pctEl.style.color  = tier.color;
    tierEl.textContent = tier.label;
    tierEl.style.color = tier.color;
    (fillEl as HTMLElement).style.background = `linear-gradient(90deg, ${tier.grad})`;
    tipEl.textContent  = missing.length
      ? `Next: ${missing[0].pts} pts for adding your ${missing[0].key.replace(/_/g,' ')}. Employers notice complete profiles.`
      : '';

    nudge.classList.remove('hidden');
    setTimeout(() => { fillEl.style.width = `${score}%`; }, 120);
  }

  init();
</script>
