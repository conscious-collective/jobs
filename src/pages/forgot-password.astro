---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Forgot Password | Sustainability Jobs"
  description="Reset your C22 Jobs password."
>
  <Nav />

  <main class="min-h-screen flex flex-col justify-center py-32">
    <div class="max-w-[480px] mx-auto w-full px-6">

      <div class="mb-8 text-center">
        <div class="section-rule mb-4 mx-auto" style="width:40px;"></div>
        <span class="tag">C22 Jobs</span>
        <h1 class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight mt-4">Forgot your password?</h1>
        <p class="text-[13px] text-[#555] mt-2">Enter your email and we'll send a reset link.</p>
      </div>

      <form id="forgot-form" class="space-y-6">
        <div>
          <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Email</label>
          <input type="email" id="fp-email" required placeholder="you@company.com"
            class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
        </div>

        <div id="fp-error" class="hidden text-[13px] text-[#ff6b35]"></div>
        <div id="fp-success" class="hidden text-[13px] text-accent"></div>

        <button type="submit" id="fp-btn"
          class="w-full py-4 text-[13px] font-display font-medium tracking-widest uppercase bg-accent text-[#080808] hover:bg-white transition-colors duration-200 disabled:opacity-40 disabled:cursor-not-allowed"
          style="clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);">
          Send Reset Link →
        </button>
      </form>

      <p class="text-center text-[12px] text-[#444] mt-8">
        <a href="/auth?mode=signin" class="hover:text-[#888] transition-colors">Back to Sign In</a>
      </p>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('forgot-form')!;
  const btn = document.getElementById('fp-btn') as HTMLButtonElement;
  const errEl = document.getElementById('fp-error')!;
  const successEl = document.getElementById('fp-success')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending…';
    errEl.classList.add('hidden');
    successEl.classList.add('hidden');

    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: (document.getElementById('fp-email') as HTMLInputElement).value,
        }),
      });

      if (res.ok) {
        successEl.textContent = 'If an account exists for that email, a reset link has been sent.';
        successEl.classList.remove('hidden');
        form.reset();
        btn.textContent = 'Sent';
      } else {
        const data = await res.json() as { error?: string };
        errEl.textContent = data.error ?? 'Something went wrong.';
        errEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Send Reset Link →';
      }
    } catch {
      errEl.textContent = 'Network error. Please try again.';
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Send Reset Link →';
    }
  });
</script>
