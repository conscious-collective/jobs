---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin · Jobs" description="">
  <div class="min-h-screen bg-[#060608] text-[#f0f0f0]">

    <!-- Sidebar -->
    <div class="fixed top-0 left-0 h-full w-[200px] border-r border-[#1a1a22] bg-[#060608] flex flex-col z-10">
      <div class="px-6 py-6 border-b border-[#1a1a22]">
        <div class="text-[11px] font-display tracking-[0.2em] uppercase text-accent mb-0.5">Admin</div>
        <div class="text-[13px] font-display text-[#f0f0f0] font-bold">Portal</div>
      </div>
      <nav class="flex-1 px-3 py-4 space-y-1">
        <a href="/admin/dashboard" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#f0f0f0] transition-colors">Dashboard</a>
        <a href="/admin/jobs" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-accent bg-accent/5 border-l border-accent">Jobs</a>
        <a href="/admin/users" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#f0f0f0] transition-colors">Users</a>
        <a href="/admin/applications" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#f0f0f0] transition-colors">Applications</a>
      </nav>
      <div class="px-3 py-4 border-t border-[#1a1a22]">
        <button id="signout" class="w-full px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#ff6b35] transition-colors text-left">Sign Out</button>
      </div>
    </div>

    <!-- Main -->
    <div class="ml-[200px] p-10">
      <div id="loading" class="text-[#444] font-display text-[12px] tracking-widest uppercase py-10">Loading…</div>

      <div id="content" class="hidden">
        <div class="mb-8 flex items-end justify-between">
          <div>
            <div class="text-[10px] font-display tracking-[0.2em] uppercase text-[#444] mb-1">Manage</div>
            <h1 class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight">Jobs</h1>
          </div>
          <div id="job-count" class="text-[13px] text-[#444] font-display"></div>
        </div>

        <div id="jobs-empty" class="hidden text-center py-16 border border-dashed border-[#1a1a22] text-[14px] text-[#444]">No jobs yet.</div>

        <div id="jobs-table" class="border border-[#1a1a22] divide-y divide-[#1a1a22]">
          <!-- Header -->
          <div class="grid grid-cols-[1fr_140px_100px_100px_110px_80px_60px] gap-4 px-5 py-3 bg-[#0a0a0a]">
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Job</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Category</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Type</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Apps</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Status</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Posted</div>
            <div></div>
          </div>
          <div id="jobs-rows"></div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const STATUS_COLOR: Record<string, string> = {
    active: 'text-emerald-600', closed: 'text-[#555]', draft: 'text-yellow-600', suspended: 'text-[#ff6b35]',
  };

  async function setStatus(id: string, status: string) {
    await fetch(`/api/admin/jobs/${id}`, {
      method: 'PATCH',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status }),
    });
    window.location.reload();
  }

  async function deleteJob(id: string, title: string) {
    if (!confirm(`Delete "${title}"? This will also remove all applications.`)) return;
    await fetch(`/api/admin/jobs/${id}`, { method: 'DELETE', credentials: 'include' });
    window.location.reload();
  }

  async function init() {
    const meRes = await fetch('/api/auth/me', { credentials: 'include' });
    if (!meRes.ok || (await meRes.json() as any).role !== 'admin') { window.location.href = '/admin'; return; }

    const jobs = await fetch('/api/admin/jobs', { credentials: 'include' }).then(r => r.json()) as any[];

    document.getElementById('loading')!.classList.add('hidden');
    document.getElementById('content')!.classList.remove('hidden');
    document.getElementById('job-count')!.textContent = `${jobs.length} total`;

    if (jobs.length === 0) {
      document.getElementById('jobs-empty')!.classList.remove('hidden');
      document.getElementById('jobs-table')!.classList.add('hidden');
      return;
    }

    document.getElementById('jobs-rows')!.innerHTML = jobs.map((j: any) => `
      <div class="grid grid-cols-[1fr_140px_100px_100px_110px_80px_60px] gap-4 px-5 py-4 items-center hover:bg-[#0a0a0a] transition-colors" data-id="${j.id}">
        <div class="min-w-0">
          <div class="text-[13px] font-display font-bold text-[#f0f0f0] truncate">${j.title}</div>
          <div class="text-[11px] text-[#444] truncate mt-0.5">${j.company} · ${j.employer_email}</div>
          ${(() => { const skills = JSON.parse(j.skills ?? '[]'); return skills.length ? `<div class="flex flex-wrap gap-1 mt-1.5">${skills.slice(0, 3).map((s: string) => `<span class="text-[9px] px-1.5 py-0.5 border border-accent/15 text-accent/50 font-display">${s}</span>`).join('')}${skills.length > 3 ? `<span class="text-[9px] text-[#333] font-display">+${skills.length - 3}</span>` : ''}</div>` : ''; })()}
        </div>
        <div class="text-[11px] text-[#555] font-display truncate">${j.category}</div>
        <div class="text-[11px] text-[#555] font-display">${j.type}${j.remote ? ' · Remote' : ''}</div>
        <div class="text-[13px] font-display text-[#888]">${j.applicant_count}</div>
        <div>
          <select class="status-select bg-[#060608] border border-[#1a1a22] text-[11px] font-display uppercase px-2 py-1.5 focus:outline-none focus:border-accent transition-colors ${STATUS_COLOR[j.status] ?? ''}" data-id="${j.id}">
            <option value="active" ${j.status === 'active' ? 'selected' : ''}>Active</option>
            <option value="closed" ${j.status === 'closed' ? 'selected' : ''}>Closed</option>
            <option value="draft" ${j.status === 'draft' ? 'selected' : ''}>Draft</option>
            <option value="suspended" ${j.status === 'suspended' ? 'selected' : ''}>Suspended</option>
          </select>
        </div>
        <div class="text-[11px] text-[#333] font-display">${new Date(j.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</div>
        <div>
          <button class="delete-btn text-[11px] font-display text-[#333] hover:text-[#ff6b35] transition-colors" data-id="${j.id}" data-title="${j.title}">Delete</button>
        </div>
      </div>
    `).join('');

    document.querySelectorAll('.status-select').forEach(sel => {
      sel.addEventListener('change', (e) => {
        const el = e.target as HTMLSelectElement;
        setStatus(el.dataset.id!, el.value);
      });
    });

    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const el = e.target as HTMLElement;
        deleteJob(el.dataset.id!, el.dataset.title!);
      });
    });

    document.getElementById('signout')!.addEventListener('click', async () => {
      await fetch('/api/auth/signout', { method: 'POST', credentials: 'include' });
      window.location.href = '/admin';
    });
  }

  init();
</script>
