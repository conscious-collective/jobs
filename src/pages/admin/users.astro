---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin · Users" description="">
  <div class="min-h-screen bg-[#060608] text-[#f0f0f0]">

    <!-- Sidebar -->
    <div class="fixed top-0 left-0 h-full w-[200px] border-r border-[#1a1a22] bg-[#060608] flex flex-col z-10">
      <div class="px-6 py-6 border-b border-[#1a1a22]">
        <div class="text-[11px] font-display tracking-[0.2em] uppercase text-accent mb-0.5">Admin</div>
        <div class="text-[13px] font-display text-[#f0f0f0] font-bold">Portal</div>
      </div>
      <nav class="flex-1 px-3 py-4 space-y-1">
        <a href="/admin/dashboard" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#f0f0f0] transition-colors">Dashboard</a>
        <a href="/admin/jobs" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#f0f0f0] transition-colors">Jobs</a>
        <a href="/admin/users" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-accent bg-accent/5 border-l border-accent">Users</a>
        <a href="/admin/applications" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#f0f0f0] transition-colors">Applications</a>
      </nav>
      <div class="px-3 py-4 border-t border-[#1a1a22]">
        <button id="signout" class="w-full px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#ff6b35] transition-colors text-left">Sign Out</button>
      </div>
    </div>

    <!-- Main -->
    <div class="ml-[200px] p-10">
      <div id="loading" class="text-[#444] font-display text-[12px] tracking-widest uppercase py-10">Loading…</div>

      <div id="content" class="hidden">
        <div class="mb-8 flex items-end justify-between">
          <div>
            <div class="text-[10px] font-display tracking-[0.2em] uppercase text-[#444] mb-1">Manage</div>
            <h1 class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight">Users</h1>
          </div>
          <div id="user-count" class="text-[13px] text-[#444] font-display"></div>
        </div>

        <div id="users-empty" class="hidden text-center py-16 border border-dashed border-[#1a1a22] text-[14px] text-[#444]">No users yet.</div>

        <div id="users-table" class="border border-[#1a1a22] divide-y divide-[#1a1a22]">
          <div class="grid grid-cols-[1fr_100px_80px_80px_100px_60px] gap-4 px-5 py-3 bg-[#0a0a0a]">
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">User</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Role</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Jobs</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Apps</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Joined</div>
            <div></div>
          </div>
          <div id="users-rows"></div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const ROLE_COLOR: Record<string, string> = {
    employer: 'border-accent/20 text-accent/70',
    seeker: 'border-[#1a1a22] text-[#555]',
  };

  async function deleteUser(id: string, email: string) {
    if (!confirm(`Delete user "${email}"? This will remove all their jobs and applications.`)) return;
    await fetch(`/api/admin/users/${id}`, { method: 'DELETE', credentials: 'include' });
    window.location.reload();
  }

  async function init() {
    const meRes = await fetch('/api/auth/me', { credentials: 'include' });
    if (!meRes.ok || (await meRes.json() as any).role !== 'admin') { window.location.href = '/admin'; return; }

    const users = await fetch('/api/admin/users', { credentials: 'include' }).then(r => r.json()) as any[];

    document.getElementById('loading')!.classList.add('hidden');
    document.getElementById('content')!.classList.remove('hidden');
    document.getElementById('user-count')!.textContent = `${users.length} total`;

    if (users.length === 0) {
      document.getElementById('users-empty')!.classList.remove('hidden');
      document.getElementById('users-table')!.classList.add('hidden');
      return;
    }

    document.getElementById('users-rows')!.innerHTML = users.map((u: any) => `
      <div class="grid grid-cols-[1fr_100px_80px_80px_100px_60px] gap-4 px-5 py-4 items-center hover:bg-[#0a0a0a] transition-colors">
        <div class="min-w-0">
          <div class="text-[13px] font-display text-[#f0f0f0] truncate">${u.email}</div>
          ${u.company_name ? `<div class="text-[11px] text-[#444] mt-0.5 truncate">${u.company_name}</div>` : ''}
        </div>
        <div>
          <span class="text-[10px] font-display tracking-widest uppercase px-2 py-0.5 border ${ROLE_COLOR[u.role] ?? ''}">${u.role}</span>
        </div>
        <div class="text-[13px] font-display text-[#888]">${u.job_count}</div>
        <div class="text-[13px] font-display text-[#888]">${u.application_count}</div>
        <div class="text-[11px] text-[#333] font-display">${new Date(u.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
        <div>
          <button class="delete-btn text-[11px] font-display text-[#333] hover:text-[#ff6b35] transition-colors" data-id="${u.id}" data-email="${u.email}">Delete</button>
        </div>
      </div>
    `).join('');

    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const el = e.target as HTMLElement;
        deleteUser(el.dataset.id!, el.dataset.email!);
      });
    });

    document.getElementById('signout')!.addEventListener('click', async () => {
      await fetch('/api/auth/signout', { method: 'POST', credentials: 'include' });
      window.location.href = '/admin';
    });
  }

  init();
</script>
