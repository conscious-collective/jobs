---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Sign In | Sustainability Jobs"
  description="Sign in or create your free account to post or apply to sustainability jobs."
>
  <Nav />

  <main class="min-h-screen flex flex-col justify-center py-32">
    <div class="max-w-[480px] mx-auto w-full px-6">

      <div class="mb-8 text-center">
        <div class="section-rule mb-4 mx-auto" style="width:40px;"></div>
        <span class="tag">C22 Jobs</span>
        <h1 id="page-title" class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight mt-4">Create your account</h1>
        <p id="page-sub" class="text-[13px] text-[#555] mt-2">Free forever. No card required.</p>
      </div>

      <div class="flex border border-[#1a1a22] mb-8">
        <button id="tab-signup" class="flex-1 py-3 text-[12px] font-display tracking-widest uppercase transition-colors bg-[#0d0d10] text-accent">Sign Up</button>
        <button id="tab-signin" class="flex-1 py-3 text-[12px] font-display tracking-widest uppercase transition-colors text-[#555] hover:text-[#888]">Sign In</button>
      </div>

      <form id="signup-form" class="space-y-6">
        <div>
          <div class="text-[11px] font-display tracking-widest uppercase text-[#444] mb-3">I am a</div>
          <div class="flex border border-[#1a1a22]">
            <button type="button" id="role-seeker" data-role="seeker"
              class="role-btn flex-1 py-3 text-[12px] font-display tracking-widest uppercase transition-colors bg-[#0d0d10] text-accent">
              Job Seeker
            </button>
            <button type="button" id="role-employer" data-role="employer"
              class="role-btn flex-1 py-3 text-[12px] font-display tracking-widest uppercase transition-colors text-[#555] hover:text-[#888]">
              Employer
            </button>
          </div>
        </div>

        <div>
          <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Email</label>
          <input type="email" id="su-email" required placeholder="you@company.com"
            class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
        </div>

        <div>
          <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Password</label>
          <input type="password" id="su-password" required placeholder="min 8 characters"
            class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
        </div>

        <div id="employer-fields" class="hidden space-y-6">
          <div>
            <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Company Name</label>
            <input type="text" id="su-company" placeholder="Acme Climate Co."
              class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Company Website</label>
            <input type="url" id="su-website" placeholder="https://acmeclimate.com"
              class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>

        <div id="su-error" class="hidden text-[13px] text-[#ff6b35]"></div>

        <button type="submit" id="su-btn"
          class="w-full py-4 text-[13px] font-display font-medium tracking-widest uppercase bg-accent text-[#080808] hover:bg-white transition-colors duration-200 disabled:opacity-40 disabled:cursor-not-allowed"
          style="clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);">
          Create Account →
        </button>
      </form>

      <form id="signin-form" class="hidden space-y-6">
        <div>
          <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Email</label>
          <input type="email" id="si-email" required placeholder="you@company.com"
            class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
        </div>
        <div>
          <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Password</label>
          <input type="password" id="si-password" required placeholder="Your password"
            class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
        </div>

        <div class="text-right">
          <a href="/forgot-password" class="text-[11px] text-[#444] hover:text-[#888] transition-colors">Forgot password?</a>
        </div>

        <div id="si-error" class="hidden text-[13px] text-[#ff6b35]"></div>

        <button type="submit" id="si-btn"
          class="w-full py-4 text-[13px] font-display font-medium tracking-widest uppercase bg-accent text-[#080808] hover:bg-white transition-colors duration-200 disabled:opacity-40"
          style="clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);">
          Sign In →
        </button>
      </form>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const initMode = params.get('mode') ?? 'signup';
  const initRole = params.get('role') ?? 'seeker';
  const redirect = params.get('redirect') ?? '';

  let currentRole = initRole as 'seeker' | 'employer';
  let currentMode = initMode;

  const signupForm = document.getElementById('signup-form')!;
  const signinForm = document.getElementById('signin-form')!;
  const tabSignup = document.getElementById('tab-signup')!;
  const tabSignin = document.getElementById('tab-signin')!;
  const title = document.getElementById('page-title')!;
  const sub = document.getElementById('page-sub')!;
  const employerFields = document.getElementById('employer-fields')!;

  function setMode(mode: string) {
    currentMode = mode;
    if (mode === 'signup') {
      signupForm.classList.remove('hidden');
      signinForm.classList.add('hidden');
      tabSignup.classList.add('bg-[#0d0d10]', 'text-accent');
      tabSignup.classList.remove('text-[#555]');
      tabSignin.classList.remove('bg-[#0d0d10]', 'text-accent');
      tabSignin.classList.add('text-[#555]');
      title.textContent = 'Create your account';
      sub.textContent = 'Free forever. No card required.';
    } else {
      signinForm.classList.remove('hidden');
      signupForm.classList.add('hidden');
      tabSignin.classList.add('bg-[#0d0d10]', 'text-accent');
      tabSignin.classList.remove('text-[#555]');
      tabSignup.classList.remove('bg-[#0d0d10]', 'text-accent');
      tabSignup.classList.add('text-[#555]');
      title.textContent = 'Welcome back';
      sub.textContent = 'Sign in to your account.';
    }
  }

  function setRole(role: 'seeker' | 'employer') {
    currentRole = role;
    document.querySelectorAll('.role-btn').forEach(btn => {
      const active = (btn as HTMLElement).dataset.role === role;
      btn.classList.toggle('bg-[#0d0d10]', active);
      btn.classList.toggle('text-accent', active);
      btn.classList.toggle('text-[#555]', !active);
    });
    employerFields.classList.toggle('hidden', role !== 'employer');
  }

  function getDashboard(role: string) {
    if (redirect) return redirect;
    return role === 'employer' ? '/employer/dashboard' : '/seeker/dashboard';
  }

  tabSignup.addEventListener('click', () => setMode('signup'));
  tabSignin.addEventListener('click', () => setMode('signin'));
  document.querySelectorAll('.role-btn').forEach(btn => {
    btn.addEventListener('click', () => setRole((btn as HTMLElement).dataset.role as 'seeker' | 'employer'));
  });

  signupForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('su-btn') as HTMLButtonElement;
    const errEl = document.getElementById('su-error')!;
    btn.disabled = true; btn.textContent = 'Creating…';
    errEl.classList.add('hidden');

    try {
      const res = await fetch('/api/auth/signup', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: (document.getElementById('su-email') as HTMLInputElement).value,
          password: (document.getElementById('su-password') as HTMLInputElement).value,
          role: currentRole,
          company_name: (document.getElementById('su-company') as HTMLInputElement)?.value || undefined,
          company_website: (document.getElementById('su-website') as HTMLInputElement)?.value || undefined,
        }),
      });

      let data: any = {};
      try { data = await res.json(); } catch {}
      if (res.ok) {
        window.location.href = getDashboard(data.role);
      } else {
        errEl.textContent = data.error ?? 'Something went wrong.';
        errEl.classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Create Account →';
      }
    } catch {
      errEl.textContent = 'Network error. Please try again.';
      errEl.classList.remove('hidden');
      btn.disabled = false; btn.textContent = 'Create Account →';
    }
  });

  signinForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('si-btn') as HTMLButtonElement;
    const errEl = document.getElementById('si-error')!;
    btn.disabled = true; btn.textContent = 'Signing in…';
    errEl.classList.add('hidden');

    try {
      const res = await fetch('/api/auth/signin', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: (document.getElementById('si-email') as HTMLInputElement).value,
          password: (document.getElementById('si-password') as HTMLInputElement).value,
        }),
      });

      let data: any = {};
      try { data = await res.json(); } catch {}
      if (res.ok) {
        window.location.href = getDashboard(data.role);
      } else {
        errEl.textContent = data.error ?? 'Invalid credentials.';
        errEl.classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Sign In →';
      }
    } catch {
      errEl.textContent = 'Network error. Please try again.';
      errEl.classList.remove('hidden');
      btn.disabled = false; btn.textContent = 'Sign In →';
    }
  });

  setMode(initMode);
  setRole(initRole as 'seeker' | 'employer');

  fetch('/api/auth/me', { credentials: 'include' }).then(async r => {
    if (r.ok) {
      const user = await r.json() as { role: string };
      window.location.href = getDashboard(user.role);
    }
  });
</script>
