---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const categories = ['Clean Energy', 'Climate Tech', 'ESG & Reporting', 'Environmental Science', 'Green Finance', 'Circular Economy'];
const types = ['Full-time', 'Part-time', 'Contract', 'Internship'];
const SKILLS = [
  'Carbon Accounting', 'Life Cycle Assessment (LCA)', 'ESG Reporting', 'CSRD Compliance',
  'GRI Standards', 'TCFD Framework', 'SBTi', 'Carbon Markets', 'Scope 1, 2 & 3 Emissions',
  'Renewable Energy', 'Climate Risk Analysis', 'Sustainability Strategy', 'Net Zero Planning',
  'Supply Chain Sustainability', 'Environmental Impact Assessment', 'Green Finance',
  'Impact Investing', 'Circular Economy', 'Biodiversity & Nature', 'Water Stewardship',
  'Sustainability Data & Analytics', 'Climate Policy', 'Stakeholder Engagement',
  'Carbon Capture & Storage', 'Clean Energy Systems', 'Sustainable Agriculture',
  'Climate Tech', 'Environmental Science', 'Just Transition', 'B Corp / Certifications',
];
---

<BaseLayout
  title="Edit Job | Sustainability Jobs"
  description="Edit your sustainability job posting."
>
  <Nav />

  <main class="pt-28 pb-24">
    <div class="max-w-[700px] mx-auto px-6">

      <div id="loading" class="py-20 text-center text-[#444] font-display text-[13px] tracking-widest uppercase">
        Loading…
      </div>

      <div id="form-content" class="hidden">
        <a href="/employer/dashboard" class="inline-flex items-center gap-2 text-[12px] text-[#444] hover:text-accent transition-colors font-display tracking-wider uppercase mb-10">
          <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M13 7H1M1 7L7 1M1 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Dashboard
        </a>

        <div class="section-rule mb-4"></div>
        <span class="tag">Edit Job</span>
        <h1 class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight mt-4 mb-2">Edit listing</h1>
        <p class="text-[13px] text-[#555] mb-10">Changes will be visible immediately on the board.</p>

        <form id="edit-form" class="space-y-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-7">
            <div>
              <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Job Title *</label>
              <input type="text" id="title" required placeholder="e.g. Carbon Analyst"
                class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
            </div>
            <div>
              <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Company Name *</label>
              <input type="text" id="company" required placeholder="Acme Climate Co."
                class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-7">
            <div>
              <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Location</label>
              <input type="text" id="location" placeholder="London, New York, Berlin…"
                class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
            </div>
            <div>
              <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Job Type *</label>
              <select id="type" required
                class="w-full bg-[#060608] border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] focus:outline-none focus:border-accent transition-colors appearance-none">
                <option value="" disabled>Select type</option>
                {types.map(t => <option value={t}>{t}</option>)}
              </select>
            </div>
          </div>

          <div>
            <label class="flex items-center gap-3 cursor-pointer group">
              <div id="remote-box"
                class="w-5 h-5 border border-[#1a1a22] flex items-center justify-center transition-all duration-200 group-hover:border-accent/50">
                <svg id="remote-check" class="hidden" width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M1.5 5L4 7.5L8.5 2.5" stroke="#00e5ff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <span class="text-[13px] text-[#888] font-display group-hover:text-[#f0f0f0] transition-colors">This is a remote position</span>
            </label>
            <input type="hidden" id="remote" value="false" />
          </div>

          <div>
            <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-3">Category *</label>
            <div class="flex flex-wrap gap-2" id="cat-btns">
              {categories.map(c => (
                <button type="button" data-cat={c}
                  class="cat-btn text-[11px] font-display tracking-[0.12em] uppercase px-3 py-1.5 border border-[#1a1a22] text-[#555] hover:border-[#333] hover:text-[#888] transition-all duration-200">
                  {c}
                </button>
              ))}
            </div>
            <input type="hidden" id="category" required />
          </div>

          <div>
            <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Salary / Compensation <span class="text-[#333]">(optional)</span></label>
            <input type="text" id="salary" placeholder="e.g. £50,000–£70,000 · $80k+ · Competitive"
              class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
          </div>

          <div>
            <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Job Description *</label>
            <textarea id="description" rows="8" required placeholder="Describe the role, responsibilities, requirements, and what makes it special..."
              class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors resize-none"></textarea>
          </div>

          <div>
            <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-3">
              Required Skills <span class="text-[#333]">(select all that apply)</span>
            </label>
            <div class="flex flex-wrap gap-2" id="skills-picker">
              {SKILLS.map(s => (
                <button type="button" data-skill={s}
                  class="skill-btn text-[10px] font-display tracking-[0.1em] uppercase px-2.5 py-1.5 border border-[#1a1a22] text-[#444] hover:border-[#333] hover:text-[#888] transition-all duration-150">
                  {s}
                </button>
              ))}
            </div>
            <p id="skills-count" class="text-[11px] text-[#333] mt-2">0 selected</p>
          </div>

          <div>
            <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">Additional Tags <span class="text-[#333]">(press Enter or comma to add)</span></label>
            <div id="tags-container" class="relative">
              <div id="tags-chips" class="flex flex-wrap gap-2 mb-3 empty:mb-0 empty:hidden"></div>
              <input type="text" id="tags-input" placeholder="e.g. Python, GIS, Stakeholder Comms"
                autocomplete="off"
                class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
              <div id="tags-dropdown" class="hidden absolute z-50 left-0 right-0 top-full mt-1 bg-[#0d0d10] border border-[#1a1a22] max-h-48 overflow-y-auto"></div>
            </div>
          </div>

          <div>
            <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase mb-2">
              External Apply URL <span class="text-[#333]">(optional, applicants apply on your site if set)</span>
            </label>
            <input type="url" id="apply-url" placeholder="https://yourcompany.com/careers/job-123"
              class="w-full bg-transparent border-b border-[#1a1a22] pb-2.5 text-[14px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
            <p class="text-[11px] text-[#333] mt-2">Leave blank to use the built-in application form.</p>
          </div>

          <!-- Qualifying Questions -->
          <div>
            <div class="flex items-center justify-between mb-4">
              <div>
                <label class="block text-[11px] font-display tracking-wider text-[#444] uppercase">
                  Qualifying Questions <span class="text-[#333]">(optional)</span>
                </label>
                <p class="text-[11px] text-[#333] mt-1">Ask applicants specific questions relevant to this role.</p>
              </div>
              <button type="button" id="add-question-btn"
                class="text-[11px] font-display tracking-widest uppercase px-3 py-2 border border-[#1a1a22] text-[#555] hover:border-accent/50 hover:text-accent transition-all shrink-0">
                + Add Question
              </button>
            </div>

            <div id="questions-list" class="space-y-4"></div>
          </div>

          <div id="edit-error" class="hidden text-[13px] text-[#ff6b35]"></div>

          <div class="flex items-center gap-4">
            <button type="submit" id="save-btn"
              class="inline-flex items-center gap-2 px-7 py-4 text-[13px] font-display font-medium tracking-widest uppercase bg-accent text-[#080808] hover:bg-white transition-colors duration-200 disabled:opacity-40"
              style="clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 0 100%);">
              Save Changes →
            </button>
            <a id="view-link" href="#"
              class="text-[12px] font-display tracking-wider uppercase text-[#444] hover:text-accent transition-colors">
              View Listing
            </a>
          </div>
        </form>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  let selectedCat = '';
  const selectedSkills = new Set<string>();
  const questions: Array<{ id: string; question: string; required: boolean }> = [];
  let jobId = '';

  // ── Tag picker ──────────────────────────────────────────────────────────────
  const selectedTags = new Set<string>();
  let allTagSuggestions: string[] = [];

  async function loadTagSuggestions() {
    try {
      const res = await fetch('/api/tags');
      if (res.ok) allTagSuggestions = await res.json() as string[];
    } catch {}
  }

  function renderTagChips() {
    const chipsEl = document.getElementById('tags-chips')!;
    chipsEl.innerHTML = Array.from(selectedTags).map(t => `
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 border border-accent/30 text-accent/70 text-[11px] font-display tracking-wide">
        ${t}
        <button type="button" class="tag-remove text-accent/40 hover:text-[#ff6b35] transition-colors text-[15px] leading-none" data-tag="${t.replace(/"/g, '&quot;')}">×</button>
      </span>
    `).join('');
    chipsEl.querySelectorAll('.tag-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedTags.delete((btn as HTMLElement).dataset.tag!);
        renderTagChips();
      });
    });
  }

  function addTag(tag: string) {
    const trimmed = tag.trim();
    if (!trimmed) return;
    selectedTags.add(trimmed);
    renderTagChips();
    (document.getElementById('tags-input') as HTMLInputElement).value = '';
    closeTagDropdown();
  }

  function showTagDropdown(query: string) {
    const dropdown = document.getElementById('tags-dropdown')!;
    const q = query.toLowerCase();
    const matches = allTagSuggestions.filter(t => !selectedTags.has(t) && t.toLowerCase().includes(q));
    const canCreate = query.trim() && !allTagSuggestions.some(t => t.toLowerCase() === q);
    if (matches.length === 0 && !canCreate) { dropdown.classList.add('hidden'); return; }
    dropdown.classList.remove('hidden');
    dropdown.innerHTML = [
      ...matches.map(t => `<button type="button" class="tag-suggest w-full text-left px-4 py-2.5 text-[12px] font-display text-[#888] hover:text-accent hover:bg-accent/5 transition-colors" data-tag="${t.replace(/"/g, '&quot;')}">${t}</button>`),
      canCreate ? `<button type="button" class="tag-create w-full text-left px-4 py-2.5 text-[12px] font-display text-[#555] hover:text-[#aaa] hover:bg-white/5 transition-colors ${matches.length ? 'border-t border-[#1a1a22]' : ''}">Create "<span class="text-accent">${query.trim()}</span>"</button>` : '',
    ].join('');
    dropdown.querySelectorAll('.tag-suggest').forEach(btn => {
      btn.addEventListener('click', () => addTag((btn as HTMLElement).dataset.tag!));
    });
    dropdown.querySelector('.tag-create')?.addEventListener('click', () => addTag(query.trim()));
  }

  function closeTagDropdown() {
    document.getElementById('tags-dropdown')!.classList.add('hidden');
  }

  function initTagPicker() {
    const input = document.getElementById('tags-input') as HTMLInputElement;
    input.addEventListener('input', () => {
      input.value ? showTagDropdown(input.value) : closeTagDropdown();
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        const val = input.value.replace(/,$/, '').trim();
        if (val) addTag(val);
      } else if (e.key === 'Escape') {
        closeTagDropdown();
      }
    });
    document.addEventListener('click', (e) => {
      if (!document.getElementById('tags-container')!.contains(e.target as Node)) closeTagDropdown();
    });
  }

  function renderQuestions() {
    const listEl = document.getElementById('questions-list')!;
    if (questions.length === 0) { listEl.innerHTML = ''; return; }
    listEl.innerHTML = questions.map((q, i) => `
      <div class="flex gap-3 items-start border border-[#1a1a22] p-4" data-q-index="${i}">
        <div class="flex-1">
          <input type="text" value="${q.question.replace(/"/g, '&quot;')}" placeholder="e.g. Describe your experience with carbon accounting tools"
            class="q-text w-full bg-transparent border-b border-[#1a1a22] pb-2 text-[13px] text-[#f0f0f0] placeholder-[#2a2a2a] focus:outline-none focus:border-accent transition-colors" />
        </div>
        <label class="flex items-center gap-2 shrink-0 cursor-pointer mt-1">
          <input type="checkbox" class="q-required accent-[#00e5ff]" ${q.required ? 'checked' : ''} />
          <span class="text-[11px] font-display text-[#444] uppercase tracking-wide">Required</span>
        </label>
        <button type="button" class="q-remove text-[#333] hover:text-[#ff6b35] transition-colors shrink-0 mt-1 text-[18px] leading-none">×</button>
      </div>
    `).join('');

    listEl.querySelectorAll('[data-q-index]').forEach(card => {
      const idx = parseInt((card as HTMLElement).dataset.qIndex!);
      card.querySelector<HTMLInputElement>('.q-text')!.addEventListener('input', e => {
        questions[idx].question = (e.target as HTMLInputElement).value;
      });
      card.querySelector<HTMLInputElement>('.q-required')!.addEventListener('change', e => {
        questions[idx].required = (e.target as HTMLInputElement).checked;
      });
      card.querySelector('.q-remove')!.addEventListener('click', () => {
        questions.splice(idx, 1);
        renderQuestions();
      });
    });
  }

  function setRemote(val: boolean) {
    const remoteInput = document.getElementById('remote') as HTMLInputElement;
    const remoteCheck = document.getElementById('remote-check')!;
    const remoteBox = document.getElementById('remote-box')!;
    remoteInput.value = val ? 'true' : 'false';
    remoteCheck.classList.toggle('hidden', !val);
    remoteBox.classList.toggle('border-accent/50', val);
  }

  function selectCategory(cat: string) {
    selectedCat = cat;
    (document.getElementById('category') as HTMLInputElement).value = cat;
    document.querySelectorAll('.cat-btn').forEach(b => {
      const active = (b as HTMLElement).dataset.cat === cat;
      b.classList.toggle('border-accent', active);
      b.classList.toggle('text-accent', active);
      b.classList.toggle('border-[#1a1a22]', !active);
      b.classList.toggle('text-[#555]', !active);
    });
  }

  function selectSkill(skill: string, select: boolean) {
    const btn = document.querySelector<HTMLElement>(`.skill-btn[data-skill="${CSS.escape(skill)}"]`);
    if (!btn) return;
    if (select) {
      selectedSkills.add(skill);
      btn.classList.add('border-accent', 'text-accent', 'bg-accent/5');
      btn.classList.remove('border-[#1a1a22]', 'text-[#444]');
    } else {
      selectedSkills.delete(skill);
      btn.classList.remove('border-accent', 'text-accent', 'bg-accent/5');
      btn.classList.add('border-[#1a1a22]', 'text-[#444]');
    }
    document.getElementById('skills-count')!.textContent = `${selectedSkills.size} selected`;
  }

  async function init() {
    const meRes = await fetch('/api/auth/me', { credentials: 'include' });
    if (!meRes.ok) { window.location.href = '/auth?mode=signin'; return; }
    const me = await meRes.json() as { role: string };
    if (me.role !== 'employer') { window.location.href = '/'; return; }

    const params = new URLSearchParams(window.location.search);
    jobId = params.get('id') ?? '';
    if (!jobId) { window.location.href = '/employer/dashboard'; return; }

    const jobRes = await fetch(`/api/employer/jobs/${jobId}`, { credentials: 'include' });
    if (!jobRes.ok) { window.location.href = '/employer/dashboard'; return; }
    const job = await jobRes.json() as any;

    // Populate fields
    (document.getElementById('title') as HTMLInputElement).value = job.title ?? '';
    (document.getElementById('company') as HTMLInputElement).value = job.company ?? '';
    (document.getElementById('location') as HTMLInputElement).value = job.location ?? '';
    (document.getElementById('salary') as HTMLInputElement).value = job.salary ?? '';
    (document.getElementById('description') as HTMLTextAreaElement).value = job.description ?? '';
    (document.getElementById('apply-url') as HTMLInputElement).value = job.apply_url ?? '';
    await loadTagSuggestions();
    (job.tags ?? []).forEach((t: string) => selectedTags.add(t));
    renderTagChips();
    (document.getElementById('type') as HTMLSelectElement).value = job.type ?? '';
    (document.getElementById('view-link') as HTMLAnchorElement).href = job.slug ? `/jobs/${job.slug}` : `/view?id=${jobId}`;

    setRemote(job.remote === 1 || job.remote === true);
    if (job.category) selectCategory(job.category);
    (job.skills ?? []).forEach((s: string) => selectSkill(s, true));

    (job.questions ?? []).forEach((q: any) => questions.push({ id: q.id ?? crypto.randomUUID(), question: q.question, required: !!q.required }));
    renderQuestions();

    document.getElementById('loading')!.classList.add('hidden');
    document.getElementById('form-content')!.classList.remove('hidden');

    // Wire up interactions
    document.getElementById('add-question-btn')!.addEventListener('click', () => {
      questions.push({ id: crypto.randomUUID(), question: '', required: false });
      renderQuestions();
      const inputs = document.querySelectorAll<HTMLInputElement>('.q-text');
      if (inputs.length) inputs[inputs.length - 1].focus();
    });

    document.querySelectorAll('.skill-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const skill = (btn as HTMLElement).dataset.skill!;
        selectSkill(skill, !selectedSkills.has(skill));
      });
    });

    const remoteBox = document.getElementById('remote-box')!;
    const remoteInput = document.getElementById('remote') as HTMLInputElement;
    remoteBox.closest('label')!.addEventListener('click', () => {
      setRemote(remoteInput.value !== 'true');
    });

    document.querySelectorAll('.cat-btn').forEach(btn => {
      btn.addEventListener('click', () => selectCategory((btn as HTMLElement).dataset.cat!));
    });

    initTagPicker();

    document.getElementById('edit-form')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('save-btn') as HTMLButtonElement;
      const errEl = document.getElementById('edit-error')!;
      btn.disabled = true; btn.textContent = 'Saving…';
      errEl.classList.add('hidden');

      const tags = Array.from(selectedTags);
      const validQuestions = questions.filter(q => q.question.trim());

      const res = await fetch(`/api/employer/jobs/${jobId}`, {
        method: 'PUT',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: (document.getElementById('title') as HTMLInputElement).value,
          company: (document.getElementById('company') as HTMLInputElement).value,
          location: (document.getElementById('location') as HTMLInputElement).value,
          remote: remoteInput.value === 'true',
          type: (document.getElementById('type') as HTMLSelectElement).value,
          category: selectedCat,
          description: (document.getElementById('description') as HTMLTextAreaElement).value,
          tags,
          skills: Array.from(selectedSkills),
          salary: (document.getElementById('salary') as HTMLInputElement).value || undefined,
          apply_url: (document.getElementById('apply-url') as HTMLInputElement).value || undefined,
          questions: validQuestions,
        }),
      });

      const data = await res.json() as any;
      if (res.ok) {
        const slug = data.slug ?? job.slug;
        window.location.href = slug ? `/jobs/${slug}` : `/view?id=${jobId}`;
      } else {
        errEl.textContent = data.error ?? 'Something went wrong.';
        errEl.classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Save Changes →';
      }
    });
  }

  init();
</script>
