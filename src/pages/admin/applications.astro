---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin · Applications" description="">
  <div class="min-h-screen bg-[#060608] text-[#f0f0f0]">

    <!-- Sidebar -->
    <div class="fixed top-0 left-0 h-full w-[200px] border-r border-[#1a1a22] bg-[#060608] flex flex-col z-10">
      <div class="px-6 py-6 border-b border-[#1a1a22]">
        <div class="text-[11px] font-display tracking-[0.2em] uppercase text-accent mb-0.5">Admin</div>
        <div class="text-[13px] font-display text-[#f0f0f0] font-bold">Portal</div>
      </div>
      <nav class="flex-1 px-3 py-4 space-y-1">
        <a href="/admin/dashboard" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#f0f0f0] transition-colors">Dashboard</a>
        <a href="/admin/jobs" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#f0f0f0] transition-colors">Jobs</a>
        <a href="/admin/users" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#f0f0f0] transition-colors">Users</a>
        <a href="/admin/applications" class="flex items-center gap-3 px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-accent bg-accent/5 border-l border-accent">Applications</a>
      </nav>
      <div class="px-3 py-4 border-t border-[#1a1a22]">
        <button id="signout" class="w-full px-3 py-2.5 text-[12px] font-display tracking-wide uppercase text-[#555] hover:text-[#ff6b35] transition-colors text-left">Sign Out</button>
      </div>
    </div>

    <!-- Main -->
    <div class="ml-[200px] p-10">
      <div id="loading" class="text-[#444] font-display text-[12px] tracking-widest uppercase py-10">Loading…</div>

      <div id="content" class="hidden">
        <div class="mb-8 flex items-end justify-between">
          <div>
            <div class="text-[10px] font-display tracking-[0.2em] uppercase text-[#444] mb-1">Manage</div>
            <h1 class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight">Applications</h1>
          </div>
          <div id="app-count" class="text-[13px] text-[#444] font-display"></div>
        </div>

        <div id="apps-empty" class="hidden text-center py-16 border border-dashed border-[#1a1a22] text-[14px] text-[#444]">No applications yet.</div>

        <div id="apps-table" class="border border-[#1a1a22] divide-y divide-[#1a1a22]">
          <div class="grid grid-cols-[1fr_1fr_100px_100px] gap-4 px-5 py-3 bg-[#0a0a0a]">
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Job</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Applicant</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Status</div>
            <div class="text-[10px] font-display tracking-widest uppercase text-[#333]">Applied</div>
          </div>
          <div id="apps-rows"></div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const STATUS_COLOR: Record<string, string> = {
    pending: 'border-[#1a1a22] text-[#555]',
    reviewed: 'border-yellow-800/40 text-yellow-600',
    accepted: 'border-emerald-800/40 text-emerald-600',
    rejected: 'border-red-900/40 text-red-700',
  };

  async function init() {
    const meRes = await fetch('/api/auth/me', { credentials: 'include' });
    if (!meRes.ok || (await meRes.json() as any).role !== 'admin') { window.location.href = '/admin'; return; }

    const apps = await fetch('/api/admin/applications', { credentials: 'include' }).then(r => r.json()) as any[];

    document.getElementById('loading')!.classList.add('hidden');
    document.getElementById('content')!.classList.remove('hidden');
    document.getElementById('app-count')!.textContent = `${apps.length} total`;

    if (apps.length === 0) {
      document.getElementById('apps-empty')!.classList.remove('hidden');
      document.getElementById('apps-table')!.classList.add('hidden');
      return;
    }

    document.getElementById('apps-rows')!.innerHTML = apps.map((a: any) => `
      <div class="grid grid-cols-[1fr_1fr_100px_100px] gap-4 px-5 py-4 items-start hover:bg-[#0a0a0a] transition-colors">
        <div class="min-w-0">
          <div class="text-[13px] font-display font-bold text-[#f0f0f0] truncate">${a.job_title}</div>
          <div class="text-[11px] text-[#444] mt-0.5 truncate">${a.company}</div>
        </div>
        <div class="min-w-0">
          <div class="text-[13px] font-display text-[#888] truncate">${a.seeker_email}</div>
          <div class="flex gap-2 mt-1.5">
            ${a.linkedin_url ? `<a href="${a.linkedin_url}" target="_blank" class="text-[10px] font-display text-accent/60 hover:text-accent transition-colors">LinkedIn →</a>` : ''}
            ${a.portfolio_url ? `<a href="${a.portfolio_url}" target="_blank" class="text-[10px] font-display text-accent/60 hover:text-accent transition-colors">Portfolio →</a>` : ''}
          </div>
        </div>
        <div>
          <span class="text-[10px] font-display tracking-widest uppercase px-2 py-0.5 border ${STATUS_COLOR[a.status] ?? ''}">${a.status}</span>
        </div>
        <div class="text-[11px] text-[#333] font-display">${new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
      </div>
    `).join('');

    document.getElementById('signout')!.addEventListener('click', async () => {
      await fetch('/api/auth/signout', { method: 'POST', credentials: 'include' });
      window.location.href = '/admin';
    });
  }

  init();
</script>
