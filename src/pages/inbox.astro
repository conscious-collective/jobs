---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Inbox | Sustainability Jobs"
  description="Your messages."
>
  <Nav />

  <main class="pt-28 pb-24">
    <div class="max-w-[720px] mx-auto px-6">

      <div id="loading" class="py-20 text-center text-[#444] font-display text-[13px] tracking-widest uppercase">
        Loading…
      </div>

      <!-- ── Conversation list (no application_id param) ─────────────────── -->
      <div id="inbox-list" class="hidden">
        <div class="section-rule mb-4"></div>
        <span class="tag">Inbox</span>
        <h1 class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight mt-4 mb-1">Messages</h1>
        <p class="text-[13px] text-[#555] mb-10">All your conversations in one place.</p>

        <div id="conversations" class="space-y-px"></div>
        <p id="inbox-empty" class="hidden text-[13px] text-[#333] italic py-12 text-center">No conversations yet.</p>
      </div>

      <!-- ── Thread view (application_id param present) ─────────────────── -->
      <div id="thread-view" class="hidden">
        <a id="back-link" href="/inbox" class="inline-flex items-center gap-2 text-[12px] text-[#444] hover:text-accent transition-colors font-display tracking-wider uppercase mb-10">
          <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M13 7H1M1 7L7 1M1 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          All messages
        </a>

        <div class="section-rule mb-4"></div>
        <span class="tag">Inbox</span>
        <h1 id="inbox-title" class="font-display font-bold text-[#f0f0f0] text-2xl tracking-tight mt-4 mb-1"></h1>
        <p id="inbox-sub" class="text-[13px] text-[#555] mb-10"></p>

        <div id="messages-list" class="space-y-3 mb-6 min-h-[120px]"></div>

        <div class="border border-[#1a1a22] p-4">
          <textarea id="msg-input" rows="3" placeholder="Type a message… (Cmd/Ctrl + Enter to send)"
            class="w-full bg-transparent text-[13px] text-[#f0f0f0] placeholder-[#333] focus:outline-none resize-none mb-3"></textarea>
          <div class="flex justify-end">
            <button id="msg-send"
              class="inline-flex items-center gap-2 px-5 py-3 text-[12px] font-display font-medium tracking-widest uppercase bg-accent text-[#080808] hover:bg-white transition-colors duration-200"
              style="clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 0 100%);">
              Send Message →
            </button>
          </div>
        </div>

        <div id="send-error" class="hidden mt-3 text-[13px] text-[#ff6b35]"></div>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const applicationId = params.get('application_id');
  let myUserId = '';
  let myRole = '';

  function escapeHtml(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function timeAgo(iso: string) {
    const diff = Date.now() - new Date(iso).getTime();
    const m = Math.floor(diff / 60000);
    if (m < 1) return 'just now';
    if (m < 60) return `${m}m ago`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ago`;
    const d = Math.floor(h / 24);
    if (d < 7) return `${d}d ago`;
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  // ── Inbox list ─────────────────────────────────────────────────────────────

  async function loadInbox() {
    const res = await fetch('/api/inbox', { credentials: 'include' });
    if (!res.ok) { window.location.href = '/auth?mode=signin'; return; }
    const convos = await res.json() as any[];

    document.getElementById('loading')!.classList.add('hidden');
    document.getElementById('inbox-list')!.classList.remove('hidden');

    if (convos.length === 0) {
      document.getElementById('inbox-empty')!.classList.remove('hidden');
      return;
    }

    const container = document.getElementById('conversations')!;
    container.innerHTML = convos.map(c => {
      const otherName = myRole === 'seeker'
        ? (c.employer_name || c.company_name || c.company)
        : (c.seeker_name || c.seeker_email);
      const lastMine = c.last_sender_id === myUserId;
      const preview = c.last_message ? escapeHtml(c.last_message.slice(0, 80)) + (c.last_message.length > 80 ? '…' : '') : '';
      const unread = c.unread_count > 0;

      return `
        <a href="/inbox?application_id=${c.application_id}"
          class="flex items-start gap-4 px-4 py-4 border border-[#1a1a22] hover:border-[#333] hover:bg-[#0a0a0d] transition-all group">
          <!-- Avatar placeholder -->
          <div class="shrink-0 w-9 h-9 rounded-full bg-[#1a1a22] flex items-center justify-center text-[11px] font-display text-[#555] uppercase">
            ${escapeHtml((otherName || '?').slice(0, 1))}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-baseline justify-between gap-2 mb-0.5">
              <span class="text-[13px] font-display ${unread ? 'text-[#f0f0f0] font-medium' : 'text-[#888]'} truncate">${escapeHtml(otherName || 'Unknown')}</span>
              <span class="text-[11px] text-[#333] shrink-0">${c.last_message_at ? timeAgo(c.last_message_at) : ''}</span>
            </div>
            <div class="text-[11px] text-[#444] mb-1 truncate">${escapeHtml(c.job_title)} · ${escapeHtml(c.company)}</div>
            <div class="flex items-center gap-2">
              <p class="text-[12px] ${unread ? 'text-[#aaa]' : 'text-[#333]'} truncate flex-1">
                ${lastMine ? '<span class="text-[#444]">You: </span>' : ''}${preview}
              </p>
              ${unread ? `<span class="shrink-0 min-w-[18px] h-[18px] rounded-full bg-accent text-[#080808] text-[10px] font-display font-bold flex items-center justify-center px-1">${c.unread_count}</span>` : ''}
            </div>
          </div>
        </a>
      `;
    }).join('');
  }

  // ── Thread view ────────────────────────────────────────────────────────────

  async function loadMessages() {
    const container = document.getElementById('messages-list')!;
    const res = await fetch(`/api/messages?application_id=${applicationId}`, { credentials: 'include' });
    const msgs = res.ok ? await res.json() as any[] : [];

    if (msgs.length === 0) {
      container.innerHTML = '<p class="text-[13px] text-[#333] italic py-8 text-center">No messages yet. Start the conversation.</p>';
      return;
    }

    container.innerHTML = msgs.map(m => {
      const isMine = m.sender_id === myUserId;
      return `
        <div class="flex ${isMine ? 'flex-row-reverse' : 'flex-row'}">
          <div class="max-w-[75%]">
            <div class="text-[10px] font-display text-[#333] mb-1 ${isMine ? 'text-right' : ''}">
              ${isMine ? 'You' : escapeHtml(m.sender_name || m.sender_email)} ·
              ${new Date(m.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}
            </div>
            <div class="text-[13px] text-[#ccc] p-4 border ${isMine ? 'border-accent/20 bg-accent/5' : 'border-[#1a1a22] bg-[#0d0d10]'} whitespace-pre-wrap leading-relaxed">${escapeHtml(m.body)}</div>
          </div>
        </div>
      `;
    }).join('');

    container.scrollTop = container.scrollHeight;

    // Refresh nav badge after marking messages read
    refreshNavBadge();
  }

  async function sendMessage() {
    const ta = document.getElementById('msg-input') as HTMLTextAreaElement;
    const body = ta.value.trim();
    if (!body) return;

    const errEl = document.getElementById('send-error')!;
    errEl.classList.add('hidden');
    const btn = document.getElementById('msg-send') as HTMLButtonElement;
    btn.disabled = true;

    const res = await fetch('/api/messages', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ application_id: applicationId, body }),
    });

    btn.disabled = false;

    if (res.ok) {
      ta.value = '';
      await loadMessages();
    } else {
      const data = await res.json() as any;
      errEl.textContent = data.error ?? 'Failed to send message.';
      errEl.classList.remove('hidden');
    }
  }

  async function loadThread() {
    const accessCheck = await fetch(`/api/messages?application_id=${applicationId}`, { credentials: 'include' });
    if (!accessCheck.ok) {
      window.location.href = myRole === 'employer' ? '/employer/dashboard' : '/seeker/dashboard';
      return;
    }

    // Get job/application info for the header
    const convos = await (await fetch('/api/inbox', { credentials: 'include' })).json() as any[];
    const convo = convos.find((c: any) => c.application_id === applicationId);
    const otherName = convo
      ? (myRole === 'seeker'
          ? (convo.employer_name || convo.company_name || convo.company)
          : (convo.seeker_name || convo.seeker_email))
      : '';

    document.getElementById('loading')!.classList.add('hidden');
    document.getElementById('thread-view')!.classList.remove('hidden');

    if (convo) {
      document.getElementById('inbox-title')!.textContent = convo.job_title + ' · ' + convo.company;
      document.getElementById('inbox-sub')!.textContent = myRole === 'employer'
        ? `Conversation with ${otherName}`
        : `Conversation with ${otherName}`;
    } else {
      document.getElementById('inbox-title')!.textContent = myRole === 'employer' ? 'Applicant Messages' : 'Messages from Employer';
      document.getElementById('inbox-sub')!.textContent = myRole === 'employer'
        ? 'Communicate directly with this applicant.'
        : 'View and reply to messages from the employer.';
    }

    const msgs = accessCheck.ok ? await accessCheck.json() as any[] : [];
    const container = document.getElementById('messages-list')!;

    if (msgs.length === 0) {
      container.innerHTML = '<p class="text-[13px] text-[#333] italic py-8 text-center">No messages yet. Start the conversation.</p>';
    } else {
      container.innerHTML = msgs.map(m => {
        const isMine = m.sender_id === myUserId;
        return `
          <div class="flex ${isMine ? 'flex-row-reverse' : 'flex-row'}">
            <div class="max-w-[75%]">
              <div class="text-[10px] font-display text-[#333] mb-1 ${isMine ? 'text-right' : ''}">
                ${isMine ? 'You' : escapeHtml(m.sender_name || m.sender_email)} ·
                ${new Date(m.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}
              </div>
              <div class="text-[13px] text-[#ccc] p-4 border ${isMine ? 'border-accent/20 bg-accent/5' : 'border-[#1a1a22] bg-[#0d0d10]'} whitespace-pre-wrap leading-relaxed">${escapeHtml(m.body)}</div>
            </div>
          </div>
        `;
      }).join('');
      container.scrollTop = container.scrollHeight;
    }

    refreshNavBadge();

    document.getElementById('msg-send')!.addEventListener('click', sendMessage);
    document.getElementById('msg-input')!.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        sendMessage();
      }
    });
  }

  // ── Nav badge helper ───────────────────────────────────────────────────────

  function refreshNavBadge() {
    fetch('/api/messages/unread', { credentials: 'include' })
      .then(r => r.ok ? r.json() : { count: 0 })
      .then((data: any) => {
        const badge = document.getElementById('nav-inbox-badge');
        if (badge) {
          badge.textContent = data.count > 0 ? String(data.count > 99 ? '99+' : data.count) : '';
          badge.classList.toggle('hidden', data.count === 0);
        }
      }).catch(() => {});
  }

  // ── Init ───────────────────────────────────────────────────────────────────

  async function init() {
    const meRes = await fetch('/api/auth/me', { credentials: 'include' });
    if (!meRes.ok) { window.location.href = '/auth?mode=signin'; return; }
    const me = await meRes.json() as { id: string; email: string; role: string };
    myUserId = me.id;
    myRole = me.role;

    if (applicationId) {
      await loadThread();
    } else {
      await loadInbox();
    }
  }

  init();
</script>
